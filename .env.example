# Research Agent Configuration
# Copy this to .env and fill in your values

# LLM Configuration
RESEARCH_LLM_DEFAULT_PROVIDER=claude
RESEARCH_LLM_GENERATION_MODEL=claude-3-5-sonnet-20241022
RESEARCH_LLM_PLANNING_MODEL=claude-3-5-sonnet-20241022
RESEARCH_LLM_SYNTHESIS_MODEL=claude-3-5-sonnet-20241022

# API Keys (get from respective services)
RESEARCH_LLM_ANTHROPIC_API_KEY=sk-ant-xxxxx
RESEARCH_LLM_OPENAI_API_KEY=sk-xxxxx

# Local LLM (if using Ollama or similar)
RESEARCH_LLM_LOCAL_BASE_URL=http://localhost:11434
RESEARCH_LLM_LOCAL_MODEL=llama2

# Sandbox Configuration
RESEARCH_SANDBOX_MODE=path-validation
RESEARCH_SANDBOX_MAX_FILE_SIZE_KB=50
RESEARCH_SANDBOX_MAX_LINE_COUNT=1000
RESEARCH_SANDBOX_MAX_SEARCH_RESULTS=100
RESEARCH_SANDBOX_TOOL_TIMEOUT_SECONDS=10
RESEARCH_SANDBOX_NETWORK_ENABLED=false

# Research Run Configuration
RESEARCH_MAX_EXPLORATORY_IDEAS=20
RESEARCH_BATCH_SIZE=5
RESEARCH_BATCH_MAX_TOKENS=8000
RESEARCH_MAX_TOOL_CALLS_PER_IDEA=10
RESEARCH_WALL_CLOCK_LIMIT_SECONDS=3600
RESEARCH_EXPLORATION_DEPTH=medium

# Storage Configuration
RESEARCH_STORAGE_DATABASE_URL=sqlite:///.research-agent/research.db
RESEARCH_STORAGE_MEMORY_INDEX_PATH=.research-agent/memory-index.json
RESEARCH_STORAGE_REPORTS_DIR=.research-agent/runs/reports

# Logging Configuration
RESEARCH_LOGGING_LEVEL=INFO
RESEARCH_LOGGING_FORMAT=json
RESEARCH_LOGGING_FILE_PATH=.research-agent/agent.log

# Debug Mode
DEBUG=false
